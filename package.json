{
  "name": "reliable-udp",
  "version": "0.1.0",
  "description": "Reliable UDP transport: multiplexed channels, SACK/NACK, fragmentation, congestion control",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvgenyAbc/reliable-udp.git"
  },
  "homepage": "https://github.com/EvgenyAbc/reliable-udp#readme",
  "bugs": {
    "url": "https://github.com/EvgenyAbc/reliable-udp/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "prepublishOnly": "npm run verify",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "udp",
    "reliable",
    "transport",
    "sack",
    "nack",
    "congestion"
  ],
  "license": "MIT"
}
